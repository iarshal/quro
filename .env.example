# =============================================================================
# QURO — Environment Variables
# Copy this file to apps/web/.env.local and fill in your real values
# =============================================================================

# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Quro

# QR session tokens expire after this many seconds (default: 300 = 5 min)
NEXT_PUBLIC_QR_SESSION_TTL=300

# ── OTP / MESSAGING (Twilio — activate before production) ────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+15551234567
# Currently running in MOCK mode — OTP is logged to console in development

# ── ENCRYPTION ───────────────────────────────────────────────────────────────
# 32-byte hex string used server-side to sign session tokens
APP_SECRET=GENERATE_WITH_openssl_rand_-hex_32

# ── MOBILE (Expo) ─────────────────────────────────────────────────────────────
# Copy the SUPABASE vars above into apps/mobile/.env as well:
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
# EXPO_PUBLIC_APP_URL=http://localhost:3000
